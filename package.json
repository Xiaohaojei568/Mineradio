{
  "name": "mineradio",
  "productName": "Mineradio",
  "version": "1.1.0",
  "description": "沉浸式音乐播放器，融合天气电台、歌词舞台、粒子视觉和 3D 歌单架。",
  "author": "Mineradio",
  "main": "desktop/main.js",
  "private": true,
  "scripts": {
    "dev:renderer": "vite --host 127.0.0.1",
    "build:renderer": "vite build",
    "start": "npm run build:renderer && electron .",
    "build:win": "npm run build:renderer && electron-builder --win nsis",
    "build:win:dir": "npm run build:renderer && electron-builder --win dir",
    "build:mac": "npm run build:renderer && electron-builder --mac dmg zip",
    "release:gitee": "node build/sync-gitee-release.js"
  },
  "build": {
    "appId": "com.mineradio.desktop",
    "productName": "Mineradio",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "afterPack": "build/after-pack.js",
    "compression": "maximum",
    "electronLanguages": [
      "zh-CN",
      "zh-TW",
      "en-US"
    ],
    "toolsets": {
      "winCodeSign": "1.1.0"
    },
    "files": [
      "desktop/**/*",
      "server/**/*",
      "src/**/*",
      "renderer-dist/**/*",
      "public/**/*",
      "build/icon.ico",
      "server.js",
      "dj-analyzer.js",
      "vite.config.js",
      "package.json",
      "!public/index.*.html",
      "public/index.html",
      "!node_modules/gsap/**/*",
      "!node_modules/xml2js/lib/xml2js.bc.js",
      "!node_modules/NeteaseCloudMusicApi/public/**/*"
    ],
    "asar": false,
    "win": {
      "executableName": "Mineradio",
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "category": "public.app-category.music",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "artifactName": "Mineradio-${version}-Mac-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Mineradio",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerSidebar": "build/installerSidebar.bmp",
      "uninstallerSidebar": "build/installerSidebar.bmp",
      "installerHeader": "build/installerHeader.bmp",
      "include": "build/installer.nsh",
      "artifactName": "Mineradio-${version}-Setup.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Xiaohaojei568",
        "repo": "Mineradio"
      }
    ]
  },
  "mineradio": {
    "update": {
      "provider": "gitee",
      "owner": "Xiaohaojei568",
      "repo": "Mineradio",
      "gitee": {
        "owner": "xiao-majie",
        "repo": "mineradio",
        "repository": "https://gitee.com/xiao-majie/mineradio.git",
        "prefer": true
      },
      "preview": true,
      "preferMirrors": true,
      "mirrors": [
        "https://gh.llkk.cc/",
        "https://ghfast.top/",
        "https://gh-proxy.com/"
      ]
    }
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "gsap": "^3.15.0",
    "mpg123-decoder": "^1.0.3",
    "NeteaseCloudMusicApi": "^4.32.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "rcedit": "^5.0.2",
    "vite": "^8.1.3",
    "vue": "^3.5.39"
  }
}
